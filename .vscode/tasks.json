{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "setup",
      "type": "shell",
      "command": "npm run setup",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-ilc"]
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false,
        "clear": false
      }
    },
    {
      "label": "dev:servers",
      "dependsOn": ["dev:backend", "dev:worker", "dev:frontend"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "dev",
      "dependsOn": ["setup", "dev:servers"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "dev:backend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-ilc"]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "crea-dashboard-backend",
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Backend running"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "close": false
      }
    },
    {
      "label": "dev:worker",
      "type": "shell",
      "command": "npm run dev:worker",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-ilc"]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "crea-dashboard-worker",
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Temporal worker starting"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "close": false
      }
    },
    {
      "label": "dev:frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-ilc"]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "crea-dashboard-frontend",
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Project is running at|compiled successfully)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "close": false
      }
    },
    {
      "label": "build",
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
