{
  "name": "crea-dev-launcher",
  "displayName": "Crea Dev Launcher",
  "description": "Starts backend, worker and frontend in separate Cursor terminals",
  "version": "0.2.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "crea-dev-launcher.startServers",
        "title": "Crea: Start Dev Servers"
      }
    ]
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  }
}
