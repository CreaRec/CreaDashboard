{
  "name": "crea-dashboard",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "setup": "node scripts/setup-dev.js",
    "dev:servers": "node scripts/dev-servers.js",
    "dev": "npm run setup && npm run dev:servers",
    "build": "npm run build -w backend && npm run build -w frontend",
    "start": "node scripts/setup-db.js && npm run start -w backend",
    "db:up": "docker compose up -d",
    "db:migrate": "npm run db:migrate:deploy -w backend",
    "test:scripts": "node --test scripts/dev-servers.test.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
