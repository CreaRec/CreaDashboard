# --- Local development (npm run db:up / npm run dev) ---
DATABASE_URL="postgresql://crea:crea@localhost:5434/crea_dashboard"
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=smt-sync

# App timezone for utility readings, SMT sync, and API date handling (IANA name)
APP_TIMEZONE=America/Chicago

# Logging (debug | info | warn | error)
LOG_LEVEL=debug

# Smart Meter Texas Portal API
SMT_USERNAME=
SMT_PASSWORD=
SMT_ESIID=
SMT_SYNC_INTERVAL_MINUTES=60
ELECTRICITY_RATE_PER_KWH=

# WaterSmart (Pflugerville)
WATERSMART_HOST=pflugervilletx
WATERSMART_EMAIL=
WATERSMART_PASSWORD=
WATERSMART_SYNC_INTERVAL_MINUTES=360

# Atmos Energy (Gas)
ATMOS_USERNAME=
ATMOS_PASSWORD=
ATMOS_SYNC_INTERVAL_MINUTES=1440
GAS_RATE_PER_CCF=

# Electricity bills (Champion Energy) — User Name from portal, not email
CHAMPION_USERNAME=
CHAMPION_PASSWORD=
CHAMPION_SYNC_INTERVAL_MINUTES=1440
CHAMPION_ACCOUNT_NUMBER=

# OpenAI (shared client)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Restrictions widget
RESTRICTIONS_SYNC_INTERVAL_MINUTES=1440
BURN_BAN_COUNTIES=Travis
WATER_RESTRICTIONS_URL=https://www.pflugervilletx.gov/current-water-restrictions

# Apple Calendar (iCloud CalDAV)
APPLE_CALDAV_URL=https://caldav.icloud.com
APPLE_ID=
APPLE_APP_PASSWORD=
APPLE_CALENDAR_NAMES=Home,Work
CALENDAR_SYNC_INTERVAL_MINUTES=30
CALENDAR_SYNC_PAST_DAYS=7
CALENDAR_SYNC_FUTURE_DAYS=90

# --- Production server bootstrap (copy to /home/crearec/crea-dashboard/.env) ---
# Compose overrides DATABASE_URL / TEMPORAL_ADDRESS for migrate/api/worker.
# IMAGE=ghcr.io/crearec/crea-dashboard
# WEB_IMAGE=ghcr.io/crearec/crea-dashboard-web
# IMAGE_TAG=main
# LAN_BIND_IP=192.168.1.135
# DASHBOARD_HTTP_PORT=3080
# TEMPORAL_UI_HTTP_PORT=8080
# TEMPORAL_CORS_ORIGIN=http://192.168.1.135:8080
# POSTGRES_USER=crea
# POSTGRES_PASSWORD=crea
# POSTGRES_DB=crea_dashboard
# NODE_ENV=production
# LOG_LEVEL=info
# PORT=3001
