generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WidgetId {
  electricityMonthly
  electricityBills
  electricityIntervals
  electricityCurrent
  waterMonthly
  waterBills
  waterDaily
  gasMonthly
  gasBills
  calendar
  reminders
  notes
  localRestrictions
}

enum UtilityType {
  electricity
  water
  gas
}

enum SmtSyncStatus {
  success
  error
  skipped
}

model WidgetLayout {
  widgetId  WidgetId @id
  position  Int      @unique
  visible   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model UtilityReading {
  id          String      @id @default(cuid())
  utilityType UtilityType
  month       DateTime @db.Date
  consumption Float
  cost        Float

  @@unique([utilityType, month])
}

model ElectricityIntervalReading {
  id        String   @id @default(cuid())
  esiid     String
  timestamp DateTime
  kwh       Float

  @@unique([esiid, timestamp])
}

model ElectricityMeterSnapshot {
  id         String   @id @default(cuid())
  esiid      String   @unique
  readingKwh Float
  readAt     DateTime
  updatedAt  DateTime @updatedAt
}

model SmtSyncLog {
  id           String        @id @default(cuid())
  status       SmtSyncStatus
  syncedAt     DateTime      @default(now())
  error        String?
  recordsCount Int           @default(0)
}

model WaterDailyReading {
  id            String   @id @default(cuid())
  accountNumber String
  date          DateTime @db.Date
  gallons       Float

  @@unique([accountNumber, date])
}

model WaterSyncLog {
  id           String        @id @default(cuid())
  status       SmtSyncStatus
  syncedAt     DateTime      @default(now())
  error        String?
  recordsCount Int           @default(0)
}

model GasSyncLog {
  id           String        @id @default(cuid())
  status       SmtSyncStatus
  syncedAt     DateTime      @default(now())
  error        String?
  recordsCount Int           @default(0)
}

model ChampionSyncLog {
  id           String        @id @default(cuid())
  status       SmtSyncStatus
  syncedAt     DateTime      @default(now())
  error        String?
  recordsCount Int           @default(0)
}

model CalendarEvent {
  id          String    @id @default(cuid())
  externalId  String
  calendarUrl String
  title       String
  start       DateTime
  end         DateTime?
  source      String
  updatedAt   DateTime  @updatedAt

  @@unique([source, externalId])
  @@index([source, start])
}

model CalendarSyncLog {
  id           String        @id @default(cuid())
  status       SmtSyncStatus
  syncedAt     DateTime      @default(now())
  error        String?
  recordsCount Int           @default(0)
}

model CalendarSyncState {
  calendarUrl String   @id
  syncToken   String?
  updatedAt   DateTime @updatedAt
}

model Reminder {
  id        String   @id @default(cuid())
  title     String
  dueDate   DateTime @db.Date
  priority  String
  completed Boolean  @default(false)
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  color     String
  updatedAt DateTime @db.Date
}

model RestrictionsSnapshot {
  id              String   @id @default("current")
  burnBanActive   Boolean
  burnBanCounty   String
  waterStage      String
  waterStageLabel String
  fetchedAt       DateTime @updatedAt
}

model RestrictionsSyncLog {
  id       String        @id @default(cuid())
  status   SmtSyncStatus
  syncedAt DateTime      @default(now())
  error    String?
}
