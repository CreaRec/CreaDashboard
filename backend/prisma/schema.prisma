generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WidgetId {
  electricityMonthly
  electricityIntervals
  electricityCurrent
  waterMonthly
  waterBills
  waterDaily
  gas
  calendar
  reminders
  notes
}

enum UtilityType {
  electricity
  water
  gas
}

enum SmtSyncStatus {
  success
  error
  skipped
}

model WidgetLayout {
  widgetId  WidgetId @id
  position  Int      @unique
  visible   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model UtilityReading {
  id          String      @id @default(cuid())
  utilityType UtilityType
  month       DateTime @db.Date
  consumption Float
  cost        Float

  @@unique([utilityType, month])
}

model ElectricityIntervalReading {
  id        String   @id @default(cuid())
  esiid     String
  timestamp DateTime
  kwh       Float

  @@unique([esiid, timestamp])
}

model ElectricityMeterSnapshot {
  id         String   @id @default(cuid())
  esiid      String   @unique
  readingKwh Float
  readAt     DateTime
  updatedAt  DateTime @updatedAt
}

model SmtSyncLog {
  id           String        @id @default(cuid())
  status       SmtSyncStatus
  syncedAt     DateTime      @default(now())
  error        String?
  recordsCount Int           @default(0)
}

model WaterDailyReading {
  id            String   @id @default(cuid())
  accountNumber String
  date          DateTime @db.Date
  gallons       Float

  @@unique([accountNumber, date])
}

model WaterSyncLog {
  id           String        @id @default(cuid())
  status       SmtSyncStatus
  syncedAt     DateTime      @default(now())
  error        String?
  recordsCount Int           @default(0)
}

model CalendarEvent {
  id     String    @id @default(cuid())
  title  String
  start  DateTime
  end    DateTime?
  source String
}

model Reminder {
  id        String   @id @default(cuid())
  title     String
  dueDate   DateTime @db.Date
  priority  String
  completed Boolean  @default(false)
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  color     String
  updatedAt DateTime @db.Date
}
